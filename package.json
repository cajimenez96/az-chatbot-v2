{
  "name": "converxa",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "chatbot-api",
    "chatbot-ui",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --filter @converxa/api start:dev",
    "dev:web": "bun run --filter @converxa/web dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint"
  },
  "trustedDependencies": [
    "argon2"
  ]
}
